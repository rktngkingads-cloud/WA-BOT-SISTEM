# Use the Graph API version displayed in Meta Developer settings.
WA_GRAPH_API_VERSION=
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=

# Temporary bootstrap allowlist for opt-in/test numbers only.
# Empty means no automatic replies are sent.
WA_ALLOWED_RECIPIENTS=60123456789

# Keep the automated nature clear in the default reply.
WA_AUTO_REPLY_TEXT=Balasan otomatis: Terima kasih, pesan Anda sudah diterima.

# Optional response data file. Responses remain separate from application code.
WA_RESPONSE_DATA_PATH=response_data.json

# Per-recipient debounce/rate-limit range.
WA_COOLDOWN_MIN_SECONDS=16
WA_COOLDOWN_MAX_SECONDS=20

# Conservative safety cap for inbound-triggered replies per opted-in contact.
WA_MAX_REPLIES_PER_CONTACT_PER_DAY=6

# Protects administrative and read-only endpoints.
WA_ADMIN_API_KEY=
WA_DB_PATH=data/wa-system.db
LOG_LEVEL=INFO
