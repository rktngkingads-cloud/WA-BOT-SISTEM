# Runtime mode:
# offline = no Meta token and no real WhatsApp delivery
# meta    = official WhatsApp Cloud API
WA_MODE=offline

# Official Meta settings. Leave empty in OFFLINE mode.
WA_GRAPH_API_VERSION=
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=

# Optional bootstrap allowlist for inbound auto-replies only.
# Prefer adding consented contacts through the CMD monitor [A].
WA_ALLOWED_RECIPIENTS=

# Automatic reply to a valid inbound message.
WA_AUTO_REPLY_TEXT="Balasan otomatis: Terima kasih, pesan Anda sudah diterima."
WA_RESPONSE_DATA_PATH=response_data.json

# Inbound auto-reply delay.
WA_COOLDOWN_MIN_SECONDS=16
WA_COOLDOWN_MAX_SECONDS=20

# Shared safety cap for automatic replies and manually queued messages.
WA_MAX_REPLIES_PER_CONTACT_PER_DAY=6

# Manual one-contact queue.
# Only one waiting message is allowed per contact.
WA_QUEUE_PROCESS_ENABLED=true
WA_QUEUE_DEFAULT_DELAY_SECONDS=30
WA_QUEUE_MIN_DELAY_SECONDS=15
WA_QUEUE_GLOBAL_GAP_SECONDS=15
WA_QUEUE_POLL_SECONDS=0.5

# CSV one-to-one queue limits.
WA_BATCH_MAX_CONTACTS=50
WA_BATCH_INITIAL_DELAY_SECONDS=30
WA_BATCH_GAP_SECONDS=20

# Real queued delivery is disabled by default even when WA_MODE=meta.
# Enable only after official Meta setup is complete and contacts are opted in.
WA_QUEUE_REAL_SEND_ENABLED=false

# Protect administrative HTTP endpoints.
WA_ADMIN_API_KEY=
WA_DB_PATH=data/wa-system.db
LOG_LEVEL=INFO

# CMD live monitor.
WA_MONITOR_REFRESH_SECONDS=1
WA_MONITOR_HEALTH_URL=http://127.0.0.1:8000/health
